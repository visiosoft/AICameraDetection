# RTSP source. Use VLC to verify the URL works before pointing the service at it.
RTSP_URL=rtsp://localhost:8554/test

# Backend webhook that receives attendance events.
BACKEND_WEBHOOK_URL=http://localhost:3000/api/attendance/events

# Optional API key sent as the X-API-Key header on every event POST.
BACKEND_API_KEY=

# Minimum YOLO confidence for a face detection to count.
DETECTION_CONFIDENCE=0.5

# Minimum cosine similarity for an embedding to be considered a match.
RECOGNITION_THRESHOLD=0.5

# Run detection on every Nth frame. Higher = faster, less responsive.
FRAME_SKIP=3

# SQLite file holding employee embeddings.
DB_PATH=./data/employees.db

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# When true, opens an OpenCV window showing detections and recognitions.
DEBUG=false

# Minimum seconds between events for the same employee.
COOLDOWN_SECONDS=60

# auto | true | false. auto picks GPU if CUDA is available, else CPU.
USE_GPU=auto
